<!DOCTYPE html>
<html>
<head>
    <title>Withdrawal History</title>

    <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">

</head>

<body class="container mt-5">

<h1>Withdrawal History</h1>

<table class="table table-striped">

<thead>

<tr>

<th>Date</th>
<th>Amount</th>
<th>Status</th>
<th>Wallet</th>
<th>Transaction ID</th>

</tr>

</thead>

<tbody>

<% withdrawals.forEach(withdrawal => { %>

<tr>

<td>
<%= withdrawal.createdAt.toLocaleString() %>
</td>

<td>
<%= withdrawal.amount %> sats
</td>

<td>
<%= withdrawal.status %>
</td>

<td>
<%= withdrawal.wallet %>
</td>

<td>
<%= withdrawal.txid || "Pending" %>
</td>

</tr>

<% }) %>

</tbody>

</table>

<a href="/wallet" class="btn btn-primary">
Back to Wallet
</a>

</body>
</html>