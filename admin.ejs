<!DOCTYPE html>
<html>
<head>

<title>Admin Dashboard</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body class="container mt-5">

<h1>Admin Dashboard</h1>

<hr>

<h2>Users</h2>

<table class="table table-bordered">

<thead>
<tr>
<th>Username</th>
<th>Points</th>
<th>Satoshis</th>
<th>Wallet</th>
</tr>
</thead>

<tbody>
<% users.forEach(user => { %>
<tr>
<td><%= user.username %></td>
<td><%= user.points %></td>
<td><%= user.satoshis %></td>
<td><%= user.wallet.address || "-" %></td>
</tr>
<% }) %>
</tbody>

</table>

<hr>

<h2>Withdrawal Requests</h2>

<table class="table table-striped">

<thead>
<tr>
<th>User</th>
<th>Amount</th>
<th>Wallet</th>
<th>Status</th>
</tr>
</thead>

<tbody>
<% withdrawals.forEach(withdrawal => { %>
<tr>
<td><%= withdrawal.user.username %></td>
<td><%= withdrawal.amount %> sats</td>
<td><%= withdrawal.wallet %></td>
<td><%= withdrawal.status %></td>
</tr>
<% }) %>
</tbody>

</table>

</body>
</html>
