<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">

<h2>Login</h2>

<form method="POST">

    <input
        class="form-control mb-3"
        name="email"
        type="email"
        placeholder="Email"
        required>

    <input
        class="form-control mb-3"
        name="password"
        type="password"
        placeholder="Password"
        required>

    <button class="btn btn-primary w-100">
        Login
    </button>

</form>

</body>
</html>