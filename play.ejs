<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">

<title>Math Quiz</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<link rel="stylesheet" href="style.css">

</head>

<body>

<div class="container py-5">

<div class="row">

<div class="col-lg-6 mx-auto">

<div class="card shadow-lg">

<div class="card-body text-center">

<h2>Bitcoin Math Quiz</h2>

<hr>

<h4 id="timer">60</h4>

<h3 id="question"></h3>


<div id="message" class="fw-bold mt-3"></div>

<h5>Lives: <span id="lives">3</span></h5>

<h5>XP: <span id="xp">0</span></h5>

<input
id="answer"
class="form-control form-control-lg text-center my-3"
autocomplete="off">

<button 
onclick="submitAnswer()"
class="btn btn-success">

Submit

</button>

<hr>

<h4>Score: <span id="score">0</span></h4>

<h5>Streak: <span id="streak">0</span></h5>

<h5>
Bitcoin Balance:
<span id="btc">
0 sats
</span>
</h5>

</div>

</div>

</div>

</div>

</div>

<script src="quiz.js"></script>

</body>
</html>