<!DOCTYPE html>
<html>
<head>

<title>Bitcoin Wallet</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

</head>

<body class="container mt-5">

<h1>
Bitcoin Wallet
</h1>

<div class="card p-4">

<h3>
Balance:
<%= user.satoshis %> sats
</h3>

<form method="POST" action="/wallet">

<select
name="type"
class="form-select mb-3">
<option value="bitcoin" <%= user.wallet.type === "bitcoin" ? "selected" : "" %>>
Bitcoin Address
</option>
<option value="lightning" <%= user.wallet.type === "lightning" ? "selected" : "" %>>
Lightning
</option>
</select>

<input
class="form-control mb-3"
name="wallet"
placeholder="Wallet Address"
value="<%= user.wallet.address %>"
>

<button class="btn btn-primary">
Save Wallet
</button>

</form>

<hr>

<form method="POST" action="/withdraw">

<input
class="form-control mb-3"
name="amount"
placeholder="Amount in sats"
>

<button class="btn btn-success">
Request Withdrawal
</button>

</form>

</div>

<a href="/history" class="btn btn-secondary mt-3">
View Withdrawal History
</a>

</body>
</html>
